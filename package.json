{
  "name": "obsidian-iterblock-plugin",
  "version": "1.0.0",
  "description": "The Iterblock plugin helps you create, branch, and navigate code iterations in Obsidian without the overhead of Git-based workflows",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "keywords": [],
  "license": "0-BSD",
  "devDependencies": {
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/view": "6.38.6",
    "@eslint/js": "9.39.4",
    "@types/node": "22.15.17",
    "esbuild": "0.25.5",
    "eslint": "9.39.4",
    "eslint-plugin-obsidianmd": "0.3.0",
    "globals": "17.6.0",
    "jiti": "2.6.1",
    "obsidian": "latest",
    "typescript": "5.8.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "yaml": "2.9.0"
  }
}
